---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, ...props } = data;
---

<li class="group">
  <a
    href={getPath(id, filePath)}
    class:list={[
      "block p-6 bg-gray-50 dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-gray-300 dark:hover:border-gray-600 transition-all",
    ]}
  >
    <div class="flex items-center gap-2 mb-3">
      <Datetime {...props} size="sm" />
      {props.tags && props.tags.slice(0, 1).map((tag: string) => (
        <span class:list={[
          "text-xs px-2 py-0.5 rounded",
          "bg-blue-100 dark:bg-blue-900 text-blue-600 dark:text-blue-300"
        ]}>
          {tag}
        </span>
      ))}
    </div>
    <Heading
      class:list={[
        "text-lg font-medium text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors",
      ]}
      style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
    >
      {title}
    </Heading>
    <p class="mt-2 text-sm text-gray-600 dark:text-gray-400 line-clamp-2">
      {description}
    </p>
  </a>
</li>