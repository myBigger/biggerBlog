---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { SITE } from "@/config";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.slice(0, 6);
---

<Layout>
  <div class="min-h-screen bg-white dark:bg-gray-900">
  <div class="min-h-screen bg-white dark:bg-gray-900">
    <!-- 顶部导航 -->
    <header class="fixed top-0 left-0 right-0 h-16 bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800 z-50">
      <div class="max-w-5xl mx-auto px-4 h-full flex items-center justify-between">
        <a href="/" class="text-lg font-semibold text-gray-900 dark:text-white">
          {SITE.title}
        </a>
        <nav class="flex items-center gap-6">
          <a href="/posts" class="text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white">文章</a>
          <a href="/tags" class="text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white">标签</a>
          <a href="/about" class="text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white">关于</a>
        </nav>
      </div>
    </header>

    <!-- 主内容 -->
    <main class="pt-24 pb-12 max-w-5xl mx-auto px-4">
      <!-- Hero区域 -->
      <section class="py-12">
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">
          必哥的技术笔记
        </h1>
        <p class="text-lg text-gray-600 dark:text-gray-400">
          记录真实踩坑和实践经验
        </p>
      </section>

      <!-- 文章网格 -->
      <section>
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-6">
          最新文章
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {recentPosts.map(post => (
            <a 
              href={`/posts/${post.id}`}
              class="block p-6 bg-gray-50 dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-gray-300 dark:hover:border-gray-600 transition-colors"
            >
              <div class="flex items-center gap-2 mb-3">
                <span class="text-sm text-gray-500 dark:text-gray-400">
                  {post.data.pubDatetime.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' })}
                </span>
                {post.data.tags && post.data.tags.slice(0, 1).map(tag => (
                  <span class="text-xs px-2 py-0.5 bg-blue-100 dark:bg-blue-900 text-blue-600 dark:text-blue-300 rounded">
                    {tag}
                  </span>
                ))}
              </div>
              <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">
                {post.data.title}
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2">
                {post.data.description}
              </p>
            </a>
          ))}
        </div>
      </section>

      <!-- 查看更多 -->
      <div class="mt-8 text-center">
        <a 
          href="/posts" 
          class="inline-flex items-center gap-2 px-6 py-2 text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white"
        >
          查看更多 →
        </a>
      </div>
    </main>

    <!-- 页脚 -->
    <footer class="py-8 border-t border-gray-200 dark:border-gray-800">
      <div class="max-w-5xl mx-auto px-4 text-center text-sm text-gray-500 dark:text-gray-400">
        © 2026 {SITE.author} · 基于 Astro 构建
      </div>
    </footer>
  </div>
</Layout>